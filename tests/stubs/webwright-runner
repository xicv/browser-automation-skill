#!/usr/bin/env bash
# Test stub for browser-delegate's BROWSER_DELEGATE_RUNNER_CMD seam.
# Args: TASK START_URL TASK_ID OUT_DIR
# Writes a canned Webwright-shaped run dir + trajectory.json and prints a final
# answer to stdout. Honors STUB_INJECT_CANARY=1 to embed the privacy sentinel
# into the trajectory, and STUB_EXIT to force a non-zero backend exit.
set -euo pipefail
task="${1:-}"; task_id="${3:-}"; out_dir="${4:-}"
: "${2:-}"  # start_url (arg 2) accepted for contract parity; unused by the stub

run_dir="${out_dir}/${task_id}_stub"
mkdir -p "${run_dir}/debug/steps"
printf '{"step":1}\n' > "${run_dir}/debug/steps/step_0001.json"
printf '{"step":2}\n' > "${run_dir}/debug/steps/step_0002.json"

leak=""
if [ "${STUB_INJECT_CANARY:-0}" = "1" ]; then
  leak="PASSWORD-CANARY"
fi

cat > "${run_dir}/trajectory.json" <<EOF
{
  "model": {
    "config": {"model_name": "glm-5.1", "leak": "${leak}"},
    "usage": {
      "cumulative_response": {
        "input_tokens": 1234,
        "output_tokens": 56,
        "total_tokens": 1290,
        "cached_input_tokens": 7000
      }
    }
  }
}
EOF

printf 'STUB-FINAL-ANSWER for: %s\n' "${task}"
exit "${STUB_EXIT:-0}"
