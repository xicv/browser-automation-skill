#!/usr/bin/env bash
# tests/stubs/secret-tool — mock of Linux `secret-tool` CLI for libsecret
# backend tests.
#
# Supports the 3 subcommands the backend uses:
#   store --label LABEL service SERVICE account NAME    (PW from stdin)
#   lookup service SERVICE account NAME                 (echo PW or exit 1)
#   clear  service SERVICE account NAME                 (remove or exit 1)
#
# State lives in ${LIBSECRET_STUB_STORE:-/tmp/libsecret-stub.json} as a flat
# JSON object {NAME: PW, ...} keyed by account. Each test should set
# LIBSECRET_STUB_STORE to a unique tempfile to keep tests isolated.
#
# Argv logged to ${STUB_LOG_FILE} (one arg per line, with ISO timestamp
# separator) so bats can assert argv shape — same pattern as the
# security stub.
#
# Stdin handling: real `secret-tool store` reads the password from stdin
# without a trailing newline-strip — what you pipe in is what gets stored.
# The stub mimics this verbatim.

set -euo pipefail

LOG_FILE="${STUB_LOG_FILE:-/tmp/secret-tool-stub.log}"
STORE="${LIBSECRET_STUB_STORE:-/tmp/libsecret-stub.json}"

{
  printf '%s\n' "--- $(date -u +%Y-%m-%dT%H:%M:%SZ) ---"
  for a in "$@"; do printf '%s\n' "${a}"; done
} >> "${LOG_FILE}"

[ -f "${STORE}" ] || printf '%s' '{}' > "${STORE}"

cmd="${1:-}"; shift || true

# Parse the flag set the backend uses. `store` may have --label LABEL before
# the attr=val pairs; lookup/clear are pure attr=val pairs.
account=""
service=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --label) shift 2 ;;
    service) service="$2"; shift 2 ;;
    account) account="$2"; shift 2 ;;
    *)       shift ;;
  esac
done

case "${cmd}" in
  store)
    [ -n "${account}" ] || { printf 'secret-tool: missing account\n' >&2; exit 2; }
    # Read PW from stdin verbatim (no trailing-newline strip).
    pw="$(cat)"
    jq --arg n "${account}" --arg p "${pw}" '. + {($n): $p}' \
      "${STORE}" > "${STORE}.tmp.$$" \
      && mv "${STORE}.tmp.$$" "${STORE}"
    ;;
  lookup)
    [ -n "${account}" ] || { printf 'secret-tool: missing account\n' >&2; exit 2; }
    val="$(jq -r --arg n "${account}" '.[$n] // ""' "${STORE}")"
    if [ -z "${val}" ]; then
      printf 'secret-tool: no item matching attribute(s)\n' >&2
      exit 1
    fi
    printf '%s' "${val}"
    ;;
  clear)
    [ -n "${account}" ] || { printf 'secret-tool: missing account\n' >&2; exit 2; }
    val="$(jq -r --arg n "${account}" '.[$n] // ""' "${STORE}")"
    if [ -z "${val}" ]; then
      printf 'secret-tool: no item matching attribute(s)\n' >&2
      exit 1
    fi
    jq --arg n "${account}" 'del(.[$n])' "${STORE}" > "${STORE}.tmp.$$" \
      && mv "${STORE}.tmp.$$" "${STORE}"
    ;;
  *)
    printf 'secret-tool stub: unsupported subcommand %s\n' "${cmd}" >&2
    exit 2
    ;;
esac
