#!/usr/bin/env bash
# tests/stubs/obscura — mock obscura binary for adapter contract tests.
#
# Behavior:
#   1. `--version` short-circuit: prints `obscura 0.0.0-stub` and exits 0
#      WITHOUT logging or fixture lookup (this path supports doctor + install
#      tests that wire OBSCURA_BIN=${STUBS_DIR}/obscura — see HANDOFF
#      "new-adapter-CI-trap" pattern).
#   2. For all other invocations:
#      a. Logs argv (newline-separated) to ${STUB_LOG_FILE:-/tmp/obscura-stub.log}
#         so tests can grep argv for leak / shape assertions.
#      b. Computes sha256 of argv (joined by NULs) and looks up
#         tests/fixtures/obscura/<sha>.json. If found, prints contents to
#         stdout and exits 0.
#      c. If no fixture matches, prints a JSON error line and exits with the
#         EXIT_TOOL_UNSUPPORTED_OP code (41) so tests detect missing fixtures
#         explicitly rather than silently passing.
#
# Mirrors tests/stubs/playwright-cli's fixture-based shape (Phase 8 part 1-ii).
# Real-browser integration lives in a separate suite (not part of this stub).

set -euo pipefail

# `--version` MUST short-circuit before logging — doctor + install tests call
# the stub indirectly via the adapter's tool_doctor_check, which reads version
# during health-check enumeration. Logging there would pollute STUB_LOG_FILE
# during tests that are unrelated to scrape-argv shape assertions.
if [ "${1:-}" = "--version" ]; then
  printf 'obscura 0.0.0-stub\n'
  exit 0
fi

LOG_FILE="${STUB_LOG_FILE:-/tmp/obscura-stub.log}"

{
  printf '%s\n' "--- $(date -u +%Y-%m-%dT%H:%M:%SZ) ---"
  for a in "$@"; do printf '%s\n' "${a}"; done
} >> "${LOG_FILE}"

hash="$(printf '%s\0' "$@" | shasum -a 256 | awk '{print $1}')"

FIXTURES_DIR="${OBSCURA_FIXTURES_DIR:-tests/fixtures/obscura}"
if [ -f "${FIXTURES_DIR}/${hash}.json" ]; then
  cat "${FIXTURES_DIR}/${hash}.json"
  exit 0
fi

printf '{"status":"error","reason":"no fixture for argv-hash %s","argv":%s}\n' \
  "${hash}" "$(printf '%s\n' "$@" | jq -R . | jq -sc .)"
exit 41
